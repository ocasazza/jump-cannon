{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jump Cannon",
  "version": "1.0.0",
  "identifier": "dev.ocasazza.jumpcannon",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": { "script": "trunk serve", "cwd": "..", "wait": false },
    "beforeBuildCommand": { "script": "trunk build --release", "cwd": ".." }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Jump Cannon",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
