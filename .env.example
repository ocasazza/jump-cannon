# jump-cannon environment overrides.
# Copy to `.env` (gitignored) for per-machine config. graph-api loads this
# automatically via dotenvy at startup; the nix devShell also sources it.

# Path to the Obsidian vault to visualize.
# Mac default:
#VAULT_ROOT=/Users/casazza/Repositories/ocasazza/obsidian/vault
# Linux default:
#VAULT_ROOT=/home/casazza/Repositories/ocasazza/obsidian/vault

# HTTP port (0 = OS picks a free one)
#GRAPH_API_PORT=0

# Skip auto-opening the browser
#GRAPH_API_NO_BROWSER=1

# Logging
#RUST_LOG=info
