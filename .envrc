# nix-direnv: activate the flake devshell on cd-into.
# Reloads automatically when flake.nix or flake.lock changes.
# https://github.com/nix-community/nix-direnv

use flake

# Source .env for VAULT_ROOT, GRAPH_API_PORT, etc. (see .env.example)
dotenv_if_exists .env

# Cargo-built binaries findable for cross-process spawning (vault-search etc.)
PATH_add target/release
PATH_add target/debug
